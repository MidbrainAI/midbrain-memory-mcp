{
  "name": "midbrain-memory-mcp",
  "version": "0.3.0",
  "description": "Persistent AI memory for coding agents (MCP server) — episodic capture and semantic search",
  "author": "MidBrain AI",
  "license": "MIT",
  "homepage": "https://memory.midbrain.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MidbrainAI/midbrain-memory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MidbrainAI/midbrain-memory-mcp/issues"
  },
  "main": "server.js",
  "type": "module",
  "bin": {
    "midbrain-memory-mcp": "server.js",
    "midbrain-memory-setup": "install.mjs"
  },
  "files": [
    "server.js",
    "install.mjs",
    "shared/",
    "plugin/",
    "claude-code/",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "llm",
    "opencode",
    "claude",
    "episodic",
    "coding-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "setup": "node install.mjs",
    "bootstrap": "npm install && husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "eslint . && vitest run",
    "prepublishOnly": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8'))\""
  },
  "lint-staged": {
    "*.{js,mjs}": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.4"
  }
}
