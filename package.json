{
  "name": "midbrain-memory-mcp",
  "version": "0.4.0",
  "description": "Persistent AI memory for coding agents (MCP server) — episodic capture and semantic search",
  "author": "MidBrain AI",
  "license": "MIT",
  "homepage": "https://memory.midbrain.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MidbrainAI/midbrain-memory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MidbrainAI/midbrain-memory-mcp/issues"
  },
  "main": "index.js",
  "type": "module",
  "bin": {
    "midbrain-memory-mcp": "index.js",
    "midbrain-memory-setup": "install.mjs"
  },
  "files": [
    "index.js",
    "mcp.mjs",
    "install.mjs",
    "shared/",
    "plugins/",
    "skills/",
    "dist/",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "llm",
    "opencode",
    "claude",
    "codex",
    "nanoclaw",
    "episodic",
    "coding-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "setup": "node install.mjs",
    "build:plugin": "esbuild shared/plugin-entry.mjs --bundle --format=esm --platform=node --external:jsonc-parser --external:smol-toml --outfile=dist/midbrain-shared.mjs",
    "bootstrap": "npm install && npm run build:plugin && husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build:plugin && eslint . && vitest run && bash scripts/check-pinned-spec.sh",
    "prepublishOnly": "npm run build:plugin && node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8'))\""
  },
  "lint-staged": {
    "*.{js,mjs}": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "smol-toml": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.4"
  }
}
